---
import { sanityClient } from 'sanity:client';
import Layout from '../layouts/Layout.astro';
import GoogleMap from '../components/GoogleMap.astro';
import Hero from '../components/Hero.astro';
import Days from '../components/Days.astro';
import Tickets from '../components/Tickets.astro';
const siteSettings = await sanityClient.fetch(`*[_type == "siteSettings"]`);

const { siteTitle } = siteSettings[0];
---

<Layout title={siteTitle} isHomePage={true}>
  <Hero />
  <Days />
  <Tickets />
  <GoogleMap />
</Layout>
