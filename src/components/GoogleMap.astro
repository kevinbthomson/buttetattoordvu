---
import { sanityClient } from 'sanity:client';

const siteSettings = await sanityClient.fetch(`*[_type == "siteSettings"]`);
const { address, hotelLink, hotelMapLink } = siteSettings[0];
---

<section class="google-map">
  <div class="container">
    <div class="map-info">
      <h2>Get here!</h2>
      <p>
        Walk-ins are welcome, but appointments are recommended to guarantee your
        spot. Check out artists and vendor links to book your appointments!
      </p>
    </div>

    <div class="map-wrapper">
      <iframe
        src="https://www.google.com/maps?q=Copper+King+Hotel+%26+Convention+Center,+Butte,+Montana&output=embed"
        width="100%"
        height="100%"
        style="border:0;"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"></iframe>
    </div>

    <div class="map-details">
      <div class="detail">
        <p style="margin-block: 2rem;">
          <a href={hotelLink} target="_blank" class="hotel-btn"
            >Book your hotel here</a
          >
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .google-map {
    border-top: 1px solid white;
    background-color: rgb(197, 221, 241);
    padding-block: 4rem;
  }

  .container {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .map-wrapper {
    box-shadow: 0 0 10px var(--blue);
    min-height: 400px;
    border-radius: 0.25rem;
    overflow: hidden;
  }

  iframe {
    min-height: 400px;
  }

  .map-info {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .map-info h2 {
    font-family: var(--heading-font);
    font-size: 2.5rem;
    margin-block: 0 1rem;
    color: var(--primary-color);
  }

  .map-info > p {
    margin-block: 0 2rem;
  }

  .detail h3 {
    margin-block: 0 0.25rem;
    color: var(--primary-color);
  }

  .detail p {
    margin-block: 0;
  }

  .hotel-btn {
    display: inline-block;
    padding: 0.5rem 1.25rem;
    background-color: var(--primary-color);
    color: var(--white);
    text-decoration: none;
    border-radius: 0.25rem;
    font-weight: 600;
    text-align: center;
    transition: opacity 0.2s ease;
    width: 100%;
  }

  .hotel-btn:hover {
    opacity: 0.85;
  }

  @media screen and (min-width: 768px) {
    .container {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }

    .map-wrapper {
      min-height: 500px;
    }

    .hotel-btn {
      width: auto;
    }
  }
</style>
