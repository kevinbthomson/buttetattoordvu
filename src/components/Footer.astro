---
import { sanityClient } from 'sanity:client';

const siteSettings = await sanityClient.fetch(`*[_type == "siteSettings"]`);

const { siteTitle, address, email, instagram, hotelMapLink } = siteSettings[0];
---

<footer>
  <div class="footer-content container">
    <div class="footer-section">
      <h3>Contact</h3>
      <p>
        <a href={hotelMapLink} target="_blank">{address}</a>
      </p>
      <p><a href=`mailto:${email}`>{email}</a></p>
    </div>

    <div class="footer-section">
      <h3>Follow us</h3>
      <ul>
        <li>
          <a href=`https://www.instagram.com/${instagram}` target="_blank">
            Instagram: @{instagram}</a
          >
        </li>
        <!-- <li>
          <a href=`https://www.facebook.com/${facebook}` target="_blank">
            Facebook: @{facebook}</a
          >
        </li> -->
      </ul>
    </div>
  </div>

  <div class="footer-bottom">
    <p>&copy; {new Date().getFullYear()} {siteTitle}. All rights reserved.</p>
  </div>
</footer>

<style>
  footer {
    background: var(--primary-color);
    color: var(--highlight-color);
    padding: 4rem 0 2rem;
    position: relative;
    overflow: hidden;
  }

  .footer-content {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .footer-section h3 {
    /* color: var(--highlight-color); */
    margin-bottom: 1rem;
    font-weight: 600;
    text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.7);
    color: #d4cfc6;
  }

  .footer-section p,
  .footer-section li {
    color: #d4cfc6;
    line-height: 1.8;
    margin-bottom: 0.5rem;
  }

  .footer-section ul {
    padding: 0;
    margin-block-start: 0;
    list-style: none;
  }

  .footer-section a {
    color: #d4cfc6;
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .footer-section a:hover {
    color: var(--highlight-color);
  }

  .footer-bottom {
    color: white;
    margin-block-start: 2rem;
    padding-block-start: 2rem;
    font-size: 1rem;
    text-align: center;
    word-wrap: balanced;
  }

  @media screen and (min-width: 768px) {
    .footer-content {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 3rem;
    }
  }
</style>
